# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Authorized User IDs (comma-separated for multiple users)
ALLOWED_USER_IDS=your_telegram_user_id

# Gemini CLI Configuration
GEMINI_CLI_COMMAND=npx @google/gemini-cli

# Optional: Timeout for Gemini CLI responses (seconds)
GEMINI_TIMEOUT=300

# Data directory for bot files (tasks, cron jobs, persona, etc.)
DATA_DIR=D:/Gemini CLI

# Groq API Key (for voice transcription via Whisper)
GROQ_API_KEY=your_groq_api_key_here
